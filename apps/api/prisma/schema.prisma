// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

generator typescript {
  provider = "prisma-generator-typescript-interfaces"
  output   = "../../packages/types/src/dto/generated"
}


datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @map("user_name")
  password  String
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  role      Role[]   @default([USER])
  email     String   @unique
  phone     String   @unique
  age       Int      @default(0)
  address   String   @default("address")
  avatar    String   @default("no image")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tokens    Token[]

  @@map("users")
}

model Token {
  token  String   @unique
  expires    DateTime
  userId String @map("user_id")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

enum Role {
  ADMIN
  USER
}

model Product {
  id           String @id @default(uuid())
  title        String
  description  String @default("Описание товара по дефолту")
  category     String
  manufacturer String
  imageUrl     String
  unit         String @default("шт") // Добавляем поле unit
  images ProductImage[] 
  
  @@map("products")
  shipmentItems ShipmentItem[]
  stockItems StockItem[]
}


model ProductImage {
  id String @id @default(uuid()) 
  productId String
  url String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@map("product_images")
}
model Message {
  id        Int      @id @default(autoincrement())
  userId    String
  userName  String
  text      String
  createdAt DateTime @default(now())
  attachments Attachment[] // Добавляем связь с вложениями
}

model Attachment {
  id        String   @id @default(uuid())
  messageId Int
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String   // Оригинальное имя файла
  fileSize  Int      // Размер в байтах
  fileType  String   // MIME тип
  filePath  String   // Путь к файлу на сервере
  uploadedAt DateTime @default(now())

  @@map("attachments")
}


model Warehouse {
  id        String   @id @default(uuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stockItems StockItem[]
  shipments  Shipment[]

  @@map("warehouses")
}

// Остатки на складе
model StockItem {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  warehouseId String   @map("warehouse_id")
  quantity    Int      @default(0)
  
  // Новые поля для цен и скидки
  purchasePrice  Float?  @map("purchase_price")   // цена закупки
  estimatePrice  Float?  @map("estimate_price")   // цена для сметы
  salePrice      Float?  @map("sale_price")       // цена для продажи
  discount       Float?  @default(0)              // скидка в процентах
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([productId, warehouseId])
  @@map("stock_items")
}

// Объект (куда отгружаем)
model Object {
  id          String   @id @default(uuid())
  name        String   @unique
  address     String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shipments Shipment[]

  @@map("objects")
}

// Отгрузка со склада на объект
model Shipment {
  id          String         @id @default(uuid())
  warehouseId String         @map("warehouse_id")
  objectId    String         @map("object_id")
  status      ShipmentStatus @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  object    Object    @relation(fields: [objectId], references: [id])
  items     ShipmentItem[]

  @@map("shipments")
}

// Позиции в отгрузке
model ShipmentItem {
  id         String   @id @default(uuid())
  shipmentId String   @map("shipment_id")
  productId  String   @map("product_id")
  quantity   Int
  createdAt  DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([shipmentId, productId])
  @@map("shipment_items")
}

enum ShipmentStatus {
  PENDING
  COMPLETED
  CANCELLED
}


model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Связи
  images      ProjectImage[]
  documents   ProjectDocument[]
  estimate    Estimate?
  
  // Для сортировки
  status      ProjectStatus @default(ACTIVE)
}

model ProjectImage {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  data      Bytes   // двоичные данные изображения
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  
  // Порядок отображения
  sortOrder Int @default(0)
}

model ProjectDocument {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  data      Bytes   // двоичные данные документа
  filename  String
  mimeType  String  // application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document и т.д.
  size      Int
  createdAt DateTime @default(now())
  
  // Тип документа
  docType   DocumentType @default(OTHER)
}

model Estimate {
  id          String   @id @default(uuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  items       EstimateItem[]
  totalCost   Float   @default(0)
  laborCost   Float?  // стоимость работ
  materialsCost Float? // стоимость материалов
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  
  // Связь с товаром (если есть каталог товаров)
  productId   String?
  
  // Или свободное описание
  name        String
  description String?
  
  quantity    Float
  unit        String   @default("шт")
  price       Float    // цена за единицу
  total       Float    // quantity * price
  
  // Тип затрат
  costType    CostType @default(MATERIAL) // MATERIAL или LABOR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DocumentType {
  SPECIFICATION  // спецификация
  DRAWING        // чертеж
  CONTRACT       // договор
  OTHER          // другое
}

enum CostType {
  MATERIAL  // материалы
  LABOR     // работа
}